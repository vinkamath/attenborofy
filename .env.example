# ElevenLabs API Configuration
# Get your API key from https://elevenlabs.io/
ELEVENLABS_API_KEY=your_api_key_here

# ElevenLabs Voice ID (optional — overrides config.json voice_id)
# The app's config.json uses a paid Attenborough-style clone. If you don't
# have access to that voice, uncomment the line below to use "George", a free
# built-in British male voice (the closest free alternative).
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# OpenAI-compatible endpoint configuration
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here
AZURE_OPENAI_DEPLOYMENT=gpt-5.3-chat
