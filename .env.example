# ElevenLabs API Configuration
# Get your API key from https://elevenlabs.io/
ELEVENLABS_API_KEY=your_api_key_here

# Azure OpenAI Configuration (OpenAI-compatible endpoint)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://riffle-eastus2-resource.openai.azure.com/openai/v1/
AZURE_OPENAI_DEPLOYMENT=gpt-5.3-chat

# Optional: Use the free-tier API test voice (ElevenLabs docs default). Ignored if VOICE_ID is set.
# TEST_VOICE=true

# Optional: Override voice ID (if set, TEST_VOICE default is not used)
# VOICE_ID=your_voice_id_here
