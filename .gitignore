# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
.pytest_cache/
.coverage
htmlcov/

# Do not use bare `lib/` or `lib64/` — they match paths like frontend/src/lib/

# Secrets and local env (Vite: .env.local, .env.*.local)
.env
*.local

# IDE — ignore editor config except shared recommendations
.idea/
**/.vscode/*
!**/.vscode/extensions.json
*.swp
*.swo

# Node / frontend
node_modules/
dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor (Windows / VS)
*.suo
*.ntvs*
*.njsproj
*.sln

# Generated narration audio (temp files are under system temp; repo MP3s are test captures)
*.mp3

# Tooling
.eslintcache

# Local CLI auth/config caches
.azure-config/
.gh-config/
/.claude
